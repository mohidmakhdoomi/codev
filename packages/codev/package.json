{
  "name": "@cluesmith/codev",
  "version": "3.0.3",
  "description": "Codev CLI - AI-assisted software development framework",
  "type": "module",
  "bin": {
    "codev": "./bin/codev.js",
    "porch": "./bin/porch.js",
    "afx": "./bin/afx.js",
    "af": "./bin/af.js",
    "consult": "./bin/consult.js",
    "team": "./bin/team.js",
    "generate-image": "./bin/generate-image.js"
  },
  "files": [
    "dist",
    "bin",
    "skeleton",
    "templates",
    "dashboard-dist",
    "scripts/forge",
    "scripts/postinstall.mjs"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm clean && tsc && pnpm build:dashboard && pnpm copy-skeleton",
    "build:dashboard": "cd ../dashboard && pnpm build && rm -rf ../../packages/codev/dashboard-dist && cp -r dist ../../packages/codev/dashboard-dist",
    "dev:dashboard": "cd ../dashboard && pnpm dev",
    "copy-skeleton": "rm -rf skeleton && cp -r ../../codev-skeleton skeleton",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest",
    "test:e2e": "pnpm build && vitest run --config vitest.e2e.config.ts",
    "test:e2e:watch": "vitest --config vitest.e2e.config.ts",
    "test:e2e:playwright": "pnpm exec playwright test",
    "test:e2e:cli": "pnpm build && vitest run --config vitest.cli.config.ts",
    "postinstall": "node ./scripts/postinstall.mjs",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@cluesmith/codev-core": "workspace:*",
    "@anthropic-ai/claude-agent-sdk": "^0.2.41",
    "@google/genai": "^1.0.0",
    "@openai/codex-sdk": "^0.130.0",
    "better-sqlite3": "^12.5.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "glob": "^11.0.0",
    "js-yaml": "^4.1.0",
    "node-pty": "^1.1.0",
    "open": "^10.1.0",
    "tree-kill": "^1.2.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@cluesmith/codev-dashboard": "workspace:*",
    "@cluesmith/codev-types": "workspace:*",
    "@playwright/test": "^1.58.0",
    "@xterm/xterm": "^5.5.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.1",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "cli",
    "codev",
    "ai",
    "development",
    "orchestration",
    "agent-farm",
    "multi-agent"
  ],
  "author": "Cluesmith",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cluesmith/codev"
  }
}
